    <icon>images\AWSLogo.png</icon>
    <projectUrl>https://github.com/aws/aws-sdk-net/</projectUrl>
    <description>AWS SDK for .NET V3 is in maintenance mode as of March 1st, 2026, with only critical bugs and security issues addressed until end of support on June 1st, 2026. See https://docs.aws.amazon.com/sdk-for-net/v4/developer-guide/net-dg-v4.html for migration guidance. The Amazon Web Services SDK for .NET - Core Runtime</description>
    <language>en-US</language>
    <tags>AWS Amazon cloud aws-sdk-v3</tags>
    <dependencies>
      <group targetFramework=".NETFramework3.5" />
