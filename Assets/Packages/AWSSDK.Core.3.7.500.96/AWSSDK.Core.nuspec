  <metadata>
    <id>AWSSDK.Core</id>
    <version>3.7.500.96</version>
    <title>AWSSDK - Core Runtime</title>
    <authors>Amazon Web Services</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">Apache-2.0</license>
